data$Month == startMonth &
data$Day == startDay &
data$Hour == startHour)
End_Date <- which(data$Year == endYear &
data$Month == endMonth &
data$Day == endDay &
data$Hour == endHour)
WHs <- sum(data$Warm_Hour[Start_Date:End_Date])
return(WHs)
}
