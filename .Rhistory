hourtemps$Day == End_Day &
hourtemps$Hour == End_Hour
)
CHs <- sum(hourtemps$Chilling_Hour[Start_Date:End_Date])
return(CHs)
}
sum_CH(hourtemps, 2008, 4, 1, 0,
2008, 10, 11, 0 )
